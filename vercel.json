{
  "version": 2,
  "rewrites": [
    {
      "source": "/uv/service/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/baremux/(.*)",
      "destination": "/baremux/$1"
    },
    {
      "source": "/uv/(.*)",
      "destination": "/uv/$1"
    },
    {
      "source": "/epoxy/(.*)",
      "destination": "/epoxy/$1"
    }
  ]
}
