{
	"name": "uv-app",
	"version": "1.0.0",
	"description": "Ultraviolet instance",
	"type": "module",
	"engines": {
		"node": ">=18.0.0"
	},
	"scripts": {
		"start": "node src/index.js",
		"build": "mkdir -p public/uv && cp -r node_modules/@titaniumnetwork-dev/ultraviolet/dist/* public/uv/ && cp -r node_modules/@mercuryworkshop/bare-mux/dist/* public/uv/",
		"format": "prettier --write .",
		"lint": "eslint ./src/",
		"lint:fix": "eslint ./src/ --fix"
	},
	"keywords": [
		"proxy"
	],
	"packageManager": "pnpm@10.28.0",
	"author": "",
	"license": "GPL-3.0-or-later",
	"devDependencies": {
		"eslint": "^9.0.0",
		"prettier": "^3.0.0"
	},
	"dependencies": {
		"@mercuryworkshop/bare-mux": "^2.1.8",
		"@mercuryworkshop/epoxy-transport": "2.1.28",
		"@titaniumnetwork-dev/ultraviolet": "^3.2.10",
		"express": "^5.0.0",
		"wisp-server-node": "1.1.7",
		"ws": "^8.18.0"
	}
}
